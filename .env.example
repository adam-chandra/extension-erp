# Public URL the browser uses to reach the API. NOT a docker-internal
# hostname (the SPA runs in the user's browser, not inside the network).
# Vite inlines this into the JS bundle at build time.
#   dev local:        http://localhost:8080/api
#   docker compose:   http://localhost:3000/api
#   production:       https://api.erp.example.com/api
VITE_API_BASE_URL=http://localhost:8080/api
