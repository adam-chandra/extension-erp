# Sample environment variables for Vercel deployment.
# Set these in: Vercel project → Settings → Environment Variables
# (Production / Preview / Development scope per your needs).
#
# Vite inlines VITE_* variables into the JS bundle at BUILD time,
# so changing this value requires a redeploy.

# Public URL the browser uses to reach the API.
# Use the Railway-deployed API base URL, including the /api suffix.
VITE_API_BASE_URL=https://your-api.up.railway.app/api
