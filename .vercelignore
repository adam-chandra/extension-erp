node_modules
dist
.env
.env.*
!.env.production.example
!.env.example
Dockerfile
docker-compose.yml
docker-entrypoint.sh
.dockerignore
DOCKER_SETUP.md
nginx.conf
Jenkinsfile
sonar-project.properties
